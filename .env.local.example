# --- Supabase ---
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Pl@ntNet ---
# Sign up at https://my.plantnet.org/ → My API key
PLANTNET_API_KEY=

# --- iNaturalist OAuth (only needed for the Day 9 observation-publishing stretch) ---
# Register an app at https://www.inaturalist.org/oauth/applications
INATURALIST_CLIENT_ID=
INATURALIST_CLIENT_SECRET=
INATURALIST_REDIRECT_URI=http://localhost:3000/api/inaturalist/callback
